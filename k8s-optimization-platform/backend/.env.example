# ============================================================
# K8s Optimization Platform — Environment Template
# Copy to .env and fill in real values before running.
# NEVER commit .env or .env.production to git.
# ============================================================

# ── Application ───────────────────────────────────────────────
APP_NAME=Kubernetes Optimization Platform
API_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Database (Supabase Postgres recommended) ──────────────────
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis / Celery (Upstash recommended) ─────────────────────
# For Upstash (TLS required): use rediss:// with ?ssl_cert_reqs=CERT_REQUIRED
# For local Redis: redis://localhost:6379/0
REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR_ENDPOINT.upstash.io:6379?ssl_cert_reqs=CERT_REQUIRED
REDIS_CACHE_TTL=3600
CELERY_BROKER_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR_ENDPOINT.upstash.io:6379?ssl_cert_reqs=CERT_REQUIRED
CELERY_RESULT_BACKEND=rediss://default:YOUR_UPSTASH_TOKEN@YOUR_ENDPOINT.upstash.io:6379?ssl_cert_reqs=CERT_REQUIRED

# ── Kubernetes ────────────────────────────────────────────────
K8S_IN_CLUSTER=false
K8S_CONFIG_PATH=/root/.kube/config
K8S_CONTEXT=

# ── Security ──────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-in-production-to-a-secure-random-string
JWT_SECRET_KEY=change-this-jwt-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin token (used to create agent API tokens via /api/tokens/generate) ───
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=change-this-admin-token-in-production

# ── OpenAI (optional — enables AI Copilot features) ──────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4000

# ── CORS ──────────────────────────────────────────────────────
# Add your server IP/domain + Firebase hosting URL
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://k8s-6d5ba.web.app,https://k8s-6d5ba.firebaseapp.com

# ── Cost Calculation ─────────────────────────────────────────
CPU_COST_PER_CORE_HOUR=0.031
MEMORY_COST_PER_GB_HOUR=0.004
STORAGE_COST_PER_GB_MONTH=0.10

# ── Carbon Footprint ─────────────────────────────────────────
CARBON_PER_KWH=0.35
CPU_WATTS_PER_CORE=10.0
MEMORY_WATTS_PER_GB=0.375

# ── Optimization ─────────────────────────────────────────────
CPU_BUFFER_PERCENTAGE=20.0
MEMORY_BUFFER_PERCENTAGE=20.0
MIN_RECOMMENDATION_CONFIDENCE=0.7
LOOKBACK_DAYS=7

# ── Auto-fix ─────────────────────────────────────────────────
AUTO_FIX_ENABLED=false
AUTO_FIX_DRY_RUN=true
AUTO_FIX_MAX_BATCH_SIZE=10

# ── Cleanup ──────────────────────────────────────────────────
CLEANUP_UNUSED_DAYS=90
CLEANUP_SAFE_DELETE_ENABLED=true

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
METRICS_COLLECTION_INTERVAL=300

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# Made with Bob
