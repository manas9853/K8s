# ============================================
# Kubernetes Optimization Platform
# Environment Configuration Template
# ============================================
# Copy this file to .env and update values

# ============================================
# Application Settings
# ============================================
APP_NAME=Kubernetes Optimization Platform
API_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/k8s_optimization
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================
# Kubernetes Configuration
# ============================================
K8S_IN_CLUSTER=false
K8S_CONFIG_PATH=~/.kube/config
K8S_CONTEXT=

# ============================================
# OpenAI Configuration (Optional)
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4000

# ============================================
# Cost Calculation (AWS Pricing)
# ============================================
CPU_COST_PER_CORE_HOUR=0.031
MEMORY_COST_PER_GB_HOUR=0.0035
STORAGE_COST_PER_GB_MONTH=0.10

# ============================================
# Carbon Footprint Calculation
# ============================================
CARBON_PER_KWH=0.35
CPU_WATTS_PER_CORE=10.0
MEMORY_WATTS_PER_GB=0.375

# ============================================
# Optimization Settings
# ============================================
CPU_BUFFER_PERCENTAGE=20.0
MEMORY_BUFFER_PERCENTAGE=20.0
MIN_RECOMMENDATION_CONFIDENCE=0.7
LOOKBACK_DAYS=7

# ============================================
# Auto-fix Settings
# ============================================
AUTO_FIX_ENABLED=false
AUTO_FIX_DRY_RUN=true
AUTO_FIX_MAX_BATCH_SIZE=10

# ============================================
# Cleanup Settings
# ============================================
CLEANUP_UNUSED_DAYS=90
CLEANUP_SAFE_DELETE_ENABLED=true

# ============================================
# Monitoring Configuration
# ============================================
PROMETHEUS_URL=http://prometheus:9090
METRICS_COLLECTION_INTERVAL=300

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Security Settings
# ============================================
SECRET_KEY=change-this-in-production-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_PER_MINUTE=60

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# Frontend Configuration
# ============================================
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# Made with Bob